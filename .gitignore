# ========================
# 1. AI 工具配置与缓存 (保留)
# ========================
.opencode/
.aider/
.cline/
*.log

# ========================
# 2. 环境变量与密钥 (保留)
# ========================
.env
secret.json

# ========================
# 3. MATLAB 核心缓存与自动保存文件
# ========================
# 脚本和函数的自动保存备份
*.asv
*.m~
*.fig~

# Simulink 缓存与生成的代码文件夹
slprj/
*.slxc
*.rtw

# C/C++ 联合编译产生的 MEX 文件 (Windows)
*.mexw32
*.mexw64
*.mexw64.pdb

# ========================
# 4. 本地实验数据与工作区 (非常重要)
# ========================
# 排除可能极大的本地工作区数据、采样信号和报表
*.mat
*.tdms
*.dat
*.csv